# ──────────────────────────────────────────────────────────────────────────────
# Seguridad para el directorio de APIs /codigo/
# ──────────────────────────────────────────────────────────────────────────────

# Bloquear acceso directo a archivos de utilidad y scripts de mantenimiento
<FilesMatch "^(coneccion|email|api_guard|migrate_passwords)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Encabezados de seguridad HTTP
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
</IfModule>
