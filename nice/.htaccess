# ──────────────────────────────────────────────────────────────────────────────
# Protección del panel administrativo /nice/
# ──────────────────────────────────────────────────────────────────────────────
# REQUISITO: AllowOverride All (o al menos AllowOverride Options FileInfo) debe
# estar habilitado en httpd.conf de XAMPP para el directorio htdocs.
#
# Si auto_prepend_file no funciona (per-directory override desactivado),
# como alternativa ajusta el php.ini principal:
#   auto_prepend_file = "C:/xampp/htdocs/gpsrealtime/nice/guard.php"
# ──────────────────────────────────────────────────────────────────────────────

# Procesar archivos .html como PHP para que el guard pueda ejecutarse
AddHandler application/x-httpd-php .html

# Auto-prepend el guard a todos los archivos PHP/HTML de este directorio
# Ruta relativa: PHP la resuelve desde el directorio del script en ejecución,
# por lo que funciona igual en Docker (/var/www/html/nice/) y en XAMPP Windows.
php_value auto_prepend_file "guard.php"

# Encabezados de seguridad HTTP
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
